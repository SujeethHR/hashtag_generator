ABACUS_API_KEY=your_api_key_here
# Optional: override the default model (route-llm auto-selects the best model)
# ABACUS_MODEL=route-llm

# Public URL the app is served from. Used for canonical, Open Graph,
# sitemap.xml, and robots.txt. Set this to your real domain in production
# (e.g. https://hashtags.example.com) so SEO/AEO tags point to the right place.
# SITE_URL=http://localhost:5000
